{
  "expo": {
    "name": "Lyfe Mobile",
    "slug": "lyfe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lyfe.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lyfe.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "lyfe",
    "extra": {
      "apiBaseUrl": "http://localhost:5000"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}